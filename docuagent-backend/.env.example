API_TOKEN=
API_BASE_URL=
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
OPENAI_TRUST_ENV=true
TEAMS_WEBHOOK_URL=
OPENAI_MODEL=gpt-4o-mini
TURNSTILE_SECRET_KEY=
