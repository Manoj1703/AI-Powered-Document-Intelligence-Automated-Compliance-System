MONGO_URI=mongodb://localhost:27017
# For Atlas, replace with:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=docagent-cluster
JWT_SECRET=change-this-very-long-random-secret
JWT_EXPIRE_SECONDS=86400
APP_ENV=development
SHOW_TRACEBACK=false
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
